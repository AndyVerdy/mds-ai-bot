# Required at runtime
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required at runtime AND build time (Dockerfile declares ARG AIRTABLE_PAT
# so Render forwards this env var into the docker build for ingest_whatsapp())
AIRTABLE_PAT=patXXXXXXXXXX.your-secret-here

# Required at runtime — Resend transactional email
RESEND_API_KEY=re_your_resend_key
EMAIL_FROM=MDS App Support <appsupport@milliondollarsellers.com>

# Required at runtime — comma-separated admin emails that bypass the Members
# allowlist on /api/auth/request-code and unlock /api/admin/* routes
ADMIN_EMAILS=andy@example.com,other@example.com

# Optional — Apple App Store reviewer bypass.
# When set, these allow a single fixed email + 6-digit code combo to log in
# without OTP delivery. Used for App Store review submissions where we don't
# know the reviewer's actual inbox. Leave unset in production rotations.
REVIEWER_EMAIL=appstore-reviewer@example.com
REVIEWER_FIXED_CODE=000000
