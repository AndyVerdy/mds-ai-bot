# Required at runtime
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required at runtime AND build time (Dockerfile declares ARG AIRTABLE_PAT
# so Render forwards this env var into the docker build for ingest_whatsapp())
AIRTABLE_PAT=patXXXXXXXXXX.your-secret-here

# Required at runtime — Resend transactional email
RESEND_API_KEY=re_your_resend_key
EMAIL_FROM=MDS App Support <appsupport@milliondollarsellers.com>

# Required at runtime — comma-separated admin emails that bypass the Members
# allowlist on /api/auth/request-code and unlock /api/admin/* routes
ADMIN_EMAILS=andy@example.com,other@example.com

# Optional — Apple App Store reviewer bypass.
# When set, these allow a single fixed email + 6-digit code combo to log in
# without OTP delivery. Used for App Store review submissions where we don't
# know the reviewer's actual inbox. Leave unset in production rotations.
REVIEWER_EMAIL=appstore-reviewer@example.com
REVIEWER_FIXED_CODE=000000

# ============================================================================
# Video platform (M1+) — required only when ENABLE_VIDEO_PLATFORM is set
# ============================================================================

# Toggle the video routes on/off. Without this, /api/videos returns 404 even
# if the schema + Mux/AAI keys are present.
ENABLE_VIDEO_PLATFORM=true

# Supabase service-role key (bypasses RLS — backend always filters by
# organization_id explicitly). Project ref is hardcoded in the code today.
SUPABASE_URL=https://nadtudwuwjhckotrngzn.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...

# Mux webhook signature secret. The webhook handler at /api/webhooks/mux
# verifies HMAC against this; fail-open if unset (dev only).
MUX_WEBHOOK_SECRET=mux-webhook-shared-secret

# Mux signed-playback-URL signing (Q16 hardening, 2026-05-08).
# MUX_SIGNING_KEY_ID is the short alphanumeric ID Mux issued.
# MUX_SIGNING_KEY is the RSA private key in PEM format (multi-line —
# Render's dashboard accepts multi-line values directly; no \n escaping).
# When either is missing, the signer falls back to bare unsigned URLs and
# logs a one-shot warning. Set both in pairs for production.
MUX_SIGNING_KEY_ID=hxnpJyewvy82w...
MUX_SIGNING_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEpQ...\n-----END RSA PRIVATE KEY-----"

# AssemblyAI — transcription job submit + webhook authenticity
ASSEMBLYAI_API_KEY=aai-your-api-key
ASSEMBLYAI_WEBHOOK_SECRET=aai-shared-webhook-secret

# Server-to-server admin path — shared secret for /api/internal/* routes
# called by the mds-video-admin app (D25). Same value on Vercel + Render.
MDS_ADMIN_INTERNAL_SECRET=long-random-shared-secret
